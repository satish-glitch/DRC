            </value>
        </inputParameters>
        <inputParameters>
            <name>sendRichBody</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
        <offset>0</offset>
        <versionString>2.0.1</versionString>
    </actionCalls>
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>When lead was created by Web from or event from then salesforce send auto mail to lead.</description>
    <environments>Default</environments>
    <interviewLabel>DRC_NBC_Send Email to Lead {!$Flow.CurrentDateTime}</interviewLabel>
