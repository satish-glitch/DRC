<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Edit_Customer_Number</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISCHANGED(DRC_NBC_Customer_Number__c),
    NOT(ISBLANK(PRIORVALUE(DRC_NBC_Customer_Number__c)))
)</errorConditionFormula>
    <errorDisplayField>DRC_NBC_Customer_Number__c</errorDisplayField>
    <errorMessage>“This field is system-generated and cannot be edited.”</errorMessage>
</ValidationRule>
