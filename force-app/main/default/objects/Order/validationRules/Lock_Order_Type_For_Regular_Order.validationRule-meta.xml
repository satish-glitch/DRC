<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lock_Order_Type_For_Regular_Order</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    RecordType.DeveloperName = &quot;Regular_Order&quot;,  
    TEXT(Type) = &quot;Sample Order&quot;        
)</errorConditionFormula>
    <errorDisplayField>Type</errorDisplayField>
    <errorMessage>For Regular Order record type, Order Type cannot be &apos;Sample Order&apos;.</errorMessage>
</ValidationRule>
